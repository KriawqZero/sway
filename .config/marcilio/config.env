# =============================================================================
# Marcilio Config — overrides de terminal, editor e paths
# Edite aqui; não altere os scripts diretamente.
# Este arquivo é carregado por marcilio-dispatch antes de cada ação.
# =============================================================================

# Terminal padrão para abrir ferramentas e editores
TERMINAL="foot"

# Editor padrão (abre configs, dotfiles, etc.)
EDITOR="nvim"

# Diretório raiz das dotfiles
DOTFILES="$HOME/dotfiles"
