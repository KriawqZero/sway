# ~/.config/sway/config
# Mesclado para Fedora Sway: mantém suas preferências + usa integrações do Fedora via config.d

seat * xcursor_theme Bibata-Modern-Classic 24

### Cores / bordas
# Formato: client.<estado> <borda> <fundo-titlebar> <texto> <indicador> <child_border>

# Janela focada: borda Surface1 discreta — indica foco sem gritar
client.focused          #494d64 #181926 #cad3f5 #f4dbd6 #494d64

# Janela inativa: borda funde com o fundo (invisível)
client.unfocused        #181926 #1e2030 #6e738d #181926 #181926

# Janela focused_inactive (último foco em outro workspace)
client.focused_inactive #363a4f #1e2030 #a5adcb #363a4f #363a4f

# Janela urgente
client.urgent           #ed8796 #ed8796 #1e2030 #ed8796 #ed8796

# Janela placeholder
client.placeholder      #363a4f #1e2030 #6e738d #363a4f #363a4f

### Bordas e gaps
# Borda pixel 2: fina o suficiente para não incomodar no foco
#default_border normal 0
#default_floating_border normal 0

gaps inner 0
gaps outer 0

workspace 1 output DP-1
workspace 2 output HDMI-A-1

#smart_borders off
#smart_gaps off

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

# Apps (suas preferências)
set $term foot
set $browser ungoogled-chromium
set $fileManager thunar

set $rofi_cmd rofi \
        -terminal '$term'
set $menu $rofi_cmd -show combi -combi-modes drun#run -modes combi

#set $menu walker

### Output / Wallpaper
# Ajuste o caminho se necessário
output * bg /home/marcilio/Wallpapers/background fill
#output * bg /home/marcilio/Wallpapers/b-277.jpg fill
#output DP-2 bg /home/marcilio/Wallpapers/b-065.jpg fill
#output HDMI-A-1 bg /home/marcilio/Wallpapers/2.jpg fill

output HDMI-A-1 {
   pos 0 0
   scale 1
   transform 270
}
# output HDMI-A-1 {
#     pos 0 0
#     scale 1
#     transform 0
# }

output DP-2 {
    mode 1920x1080@144Hz
#     pos 1920 0
    pos 1080 240
    scale 1
}

### Input (ABNT2)
input type:keyboard {
    xkb_layout br
    xkb_variant abnt2
}

# Mouse accel (equivalente ao "flat")
input type:pointer {
    accel_profile flat
    pointer_accel -0.2
}

input type:touchpad {
    natural_scroll disabled
}

### Autostart
# IMPORTANTE:
# No Fedora Sway, dbus/systemd/XDG env já são tratados por:
# /etc/sway/config.d/10-systemd-session.conf
# então NÃO repetimos dbus-update-activation-environment aqui.

# Tema GTK (se quiser manter)
exec gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
exec gsettings set org.gnome.desktop.interface gtk-theme "catppuccin-macchiato-lavender-standard+default"

# Elephant (walker depende dele) - descomente se for continuar usando
# exec elephant

# Waybar (mata instância anterior ao recarregar config)
exec_always sh -c 'pkill -x waybar; waybar -c ~/.config/waybar/config.jsonc -s ~/.config/waybar/style.css'

### Key bindings (suas preferências + alguns úteis do Fedora)

# swaylock 
bindsym $mod+Mod1+l exec swaylock -f

# Terminal
bindsym $mod+Return exec $term
bindsym $mod+q exec $term

# Kill focused
bindsym $mod+Shift+q kill

# Launcher
bindsym $mod+d exec $menu

# Toggle Waybar
bindsym $mod+Escape exec sh -c 'pkill -x waybar || waybar -c ~/.config/waybar/config.jsonc -s ~/.config/waybar/style.css'

# Apps
bindsym $mod+e exec $fileManager
#bindsym $mod+n exec $browser
bindsym $mod+n exec gtk-launch app.zen_browser.zen
bindsym $mod+f exec ferdium
bindsym $mod+m exec gtk-launch com.spotify.Client
bindsym $mod+Shift+n exec foot --working-directory=$HOME nvim
bindsym $mod+c exec cursor

# Sway helpers (Fedora default úteis)
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Sair do Sway? Isso encerrará sua sessão Wayland.' -B 'Sim, sair' 'swaymsg exit'

# Focus (vim)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Focus (setas também, estilo Fedora)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Move window (setas também)
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Floating / split / layout
# (Mantendo sua lógica Hypr-like e evitando conflito com seus binds de app)
bindsym $mod+v floating toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+s layout toggle split
bindsym $mod+b splith
bindsym $mod+Shift+v splitv
bindsym $mod+w layout tabbed
bindsym $mod+Shift+w layout stacking
bindsym $mod+Shift+f fullscreen
bindsym $mod+space focus mode_toggle
#bindsym $mod+Shift+p focus parent

# Mouse move/resize
floating_modifier $mod normal

# Workspaces (seu esquema: 1-5 e Alt+1-5 => 6-10)
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5

bindsym $mod+Mod1+1 workspace number 6
bindsym $mod+Mod1+2 workspace number 7
bindsym $mod+Mod1+3 workspace number 8
bindsym $mod+Mod1+4 workspace number 9
bindsym $mod+Mod1+5 workspace number 10

# (Opcional) atalhos diretos também, se quiser manter compatibilidade mental com padrão
# bindsym $mod+6 workspace number 6
# bindsym $mod+7 workspace number 7
# bindsym $mod+8 workspace number 8
# bindsym $mod+9 workspace number 9
# bindsym $mod+0 workspace number 10

# Move container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

### Resize mode (seu estilo)
mode "resize" {
    bindsym h resize shrink width 40px
    bindsym l resize grow width 40px
    bindsym k resize shrink height 40px
    bindsym j resize grow height 40px

    # Setas também (conveniência Fedora)
    bindsym Left resize shrink width 40px
    bindsym Right resize grow width 40px
    bindsym Up resize shrink height 40px
    bindsym Down resize grow height 40px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+r mode "resize"

### Scratchpad (seu atalho)
bindsym $mod+Shift+a move scratchpad
bindsym $mod+a scratchpad show

### Screenshots
# Win+Shift+S: captura de região rápida (mantido)
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy
# Print: menu completo de captura
bindsym Print exec ~/.config/sway/scripts/screenshot.sh
bindsym $mod+Shift+p exec ~/.config/sway/scripts/screenshot.sh

