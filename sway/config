# IMPORTANTE (Fedora):
# Use o sistema de includes em camadas do Fedora para herdar integrações
# (/usr/share, /etc e ~/.config/sway/config.d), incluindo session.sh/cgroups.
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
