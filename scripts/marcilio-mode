#!/usr/bin/env bash
# ==============================================================================
# marcilio-mode — troca o modo visual do Sway
# Uso: marcilio-mode <normal|foco|musica>
# ==============================================================================

MODE="${1:-}"
DOTFILES="${HOME}/dotfiles"
MODES_DIR="${DOTFILES}/modes"
STATE_DIR="${HOME}/.local/share/marcilio-mode"

# ── Paleta para mensagens ──────────────────────────────────────────────────
BOLD='\033[1m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'

info()    { echo -e "${CYAN}→${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*" >&2; }

# ── Validação ─────────────────────────────────────────────────────────────
case "${MODE}" in
  normal|foco|musica) ;;
  "")
    echo -e "Uso: ${BOLD}marcilio-mode${NC} <normal|foco|musica>"
    echo ""
    CURRENT=$(cat "${STATE_DIR}/current" 2>/dev/null || echo "—")
    echo -e "  Modo atual: ${BOLD}${CURRENT}${NC}"
    exit 0 ;;
  *)
    echo "Erro: modo inválido '${MODE}'" >&2
    echo "Modos disponíveis: normal · foco · musica" >&2
    exit 1 ;;
esac

MODE_DIR="${MODES_DIR}/${MODE}"

if [ ! -d "${MODE_DIR}" ]; then
  echo "Erro: diretório do modo não encontrado: ${MODE_DIR}" >&2
  exit 1
fi

info "Ativando modo visual: ${BOLD}${MODE}${NC}"

# ── 1. Swap symlinks ───────────────────────────────────────────────────────
info "Atualizando symlinks..."

ln -sf "${MODE_DIR}/waybar.jsonc"  "${DOTFILES}/waybar/config.jsonc"
ln -sf "${MODE_DIR}/waybar.css"    "${DOTFILES}/waybar/style.css"
ln -sf "${MODE_DIR}/rofi.rasi"     "${DOTFILES}/rofi/theme.rasi"
ln -sf "${MODE_DIR}/sway.inc"      "${DOTFILES}/sway/config.d/99-mode.conf"

# ── 2. Salvar estado atual ─────────────────────────────────────────────────
mkdir -p "${STATE_DIR}"
echo "${MODE}" > "${STATE_DIR}/current"

# Resolver wallpaper do modo
WALLPAPER_FILE="${MODE_DIR}/wallpaper"
WALLPAPER=""
if [ -f "${WALLPAPER_FILE}" ]; then
  WALLPAPER=$(tr -d '[:space:]' < "${WALLPAPER_FILE}")
  WALLPAPER="${WALLPAPER/#~/${HOME}}"
fi
[ -n "${WALLPAPER}" ] && echo "${WALLPAPER}" > "${STATE_DIR}/wallpaper"

# ── 3. Reload Sway (aplica 99-mode.conf: gaps, bordas, cores) ─────────────
info "Recarregando Sway..."
swaymsg reload

# ── 4. Reiniciar Waybar ────────────────────────────────────────────────────
sleep 0.4  # dar tempo ao exec_always do Sway terminar
info "Reiniciando Waybar..."

if /usr/bin/systemctl --user is-active --quiet waybar 2>/dev/null; then
  /usr/bin/systemctl --user restart waybar
else
  pkill -x waybar 2>/dev/null || true
  sleep 0.25
  waybar -c "${HOME}/.config/waybar/config.jsonc" \
         -s "${HOME}/.config/waybar/style.css" &
  disown $!
fi

# ── 5. Trocar wallpaper via swaybg ────────────────────────────────────────
if [ -n "${WALLPAPER}" ]; then
  if [ -f "${WALLPAPER}" ]; then
    info "Trocando wallpaper..."
    pkill swaybg 2>/dev/null || true
    sleep 0.15
    swaybg -i "${WALLPAPER}" -m fill &
    disown $!
    echo "   ${WALLPAPER}"
  else
    warn "Wallpaper não encontrado: ${WALLPAPER}"
    warn "Coloque uma imagem em: ${WALLPAPER}"
    warn "O wallpaper atual foi mantido."
  fi
fi

# ── Notificação via dunst ──────────────────────────────────────────────────
declare -A ICONS=(
  [normal]="preferences-desktop-theme"
  [foco]="applications-education"
  [musica]="audio-headphones"
)
declare -A LABELS=(
  [normal]=" Normal"
  [foco]=" Foco"
  [musica]=" Música"
)

notify-send \
  "Modo Visual" \
  "${LABELS[${MODE}]:-${MODE}}" \
  --icon="${ICONS[${MODE}]:-preferences-desktop}" \
  -t 2000 2>/dev/null || true

success "Modo '${BOLD}${MODE}${NC}' ativado"
